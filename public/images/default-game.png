<svg xmlns="http://www.w3.org/2000/svg" width="400" height="225" viewBox="0 0 400 225">
  <rect width="400" height="225" fill="#0d1526"/>
  <rect x="1" y="1" width="398" height="223" fill="none" stroke="#1e3a5f" stroke-width="2"/>
  <!-- Grid lines -->
  <line x1="0" y1="112" x2="400" y2="112" stroke="#1a2a45" stroke-width="1"/>
  <line x1="200" y1="0" x2="200" y2="225" stroke="#1a2a45" stroke-width="1"/>
  <!-- Controller shape -->
  <g transform="translate(200,112)">
    <ellipse cx="-30" cy="0" rx="45" ry="30" fill="#152040" stroke="#2a4a7f" stroke-width="2"/>
    <ellipse cx="30" cy="0" rx="45" ry="30" fill="#152040" stroke="#2a4a7f" stroke-width="2"/>
    <rect x="-15" y="-15" width="30" height="30" rx="5" fill="#152040" stroke="#2a4a7f" stroke-width="2"/>
    <!-- D-pad -->
    <rect x="-38" y="-5" width="18" height="10" rx="2" fill="#3b82f6" opacity="0.6"/>
    <rect x="-33" y="-10" width="8" height="20" rx="2" fill="#3b82f6" opacity="0.6"/>
    <!-- Buttons -->
    <circle cx="38" cy="-8" r="5" fill="#ef4444" opacity="0.7"/>
    <circle cx="30" cy="-16" r="5" fill="#10b981" opacity="0.7"/>
    <circle cx="46" cy="-16" r="5" fill="#f59e0b" opacity="0.7"/>
    <circle cx="30" cy="0" r="5" fill="#3b82f6" opacity="0.7"/>
  </g>
  <text x="200" y="175" font-family="monospace" font-size="12" fill="#2a4a7f" text-anchor="middle">GAMESZ</text>
</svg>
