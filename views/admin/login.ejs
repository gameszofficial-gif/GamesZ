<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Gamesz Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@600;900&family=Rajdhani:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">
<section class="admin-login-section">
  <div class="admin-login-card">
    <div class="admin-logo"><span class="logo-g">G</span>AMESZ <span class="admin-tag">ADMIN</span></div>
    <h2>Administrator Access</h2>
    <% if (error) { %><div class="error-banner">⚠️ <%= error %></div><% } %>
    <form method="POST" action="/admin/login" class="auth-form">
      <div class="form-group">
        <label>Username</label>
        <input type="text" name="username" placeholder="Admin username" required>
      </div>
      <div class="form-group">
        <label>Password</label>
        <input type="password" name="password" placeholder="Admin password" required>
      </div>
      <button type="submit" class="btn-auth">🔐 Login to Admin</button>
    </form>
  </div>
</section>
</body>
</html>
