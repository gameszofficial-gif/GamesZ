<%- include('partials/header', { pageTitle: product ? 'Edit Product' : 'Add Product', active: product ? 'products' : 'new-product' }) %>

<div class="admin-page-header">
  <h1><%= product ? '✏️ Edit Product' : '➕ Add New Product' %></h1>
  <a href="/admin/products" class="btn-admin-outline">← Back to Products</a>
</div>

<% if (error) { %><div class="error-banner">⚠️ <%= error %></div><% } %>

<div class="admin-form-card">
  <form method="POST" action="/admin/products/<%= product ? 'edit/' + product._id : 'new' %>" enctype="multipart/form-data" class="admin-form">

    <div class="form-row">
      <div class="form-group">
        <label>Product Name *</label>
        <input type="text" name="name" value="<%= product?.name || '' %>" placeholder="e.g. GTA V Steam Key" required>
      </div>
      <div class="form-group">
        <label>Platform</label>
        <input type="text" name="platform" value="<%= product?.platform || 'PC' %>" placeholder="PC / PS5 / Xbox">
      </div>
    </div>

    <div class="form-group">
      <label>Description *</label>
      <textarea name="description" rows="4" placeholder="Describe the product..." required><%= product?.description || '' %></textarea>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label>Price (₹) *</label>
        <input type="number" name="price" value="<%= product?.price || '' %>" placeholder="999" required min="1">
      </div>
      <div class="form-group">
        <label>Original Price (₹) — for showing discount</label>
        <input type="number" name="originalPrice" value="<%= product?.originalPrice || '' %>" placeholder="1499 (optional)">
      </div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label>Category *</label>
        <select name="category">
          <option value="steam" <%= product?.category === 'steam' ? 'selected' : '' %>>Steam Game</option>
          <option value="account" <%= product?.category === 'account' ? 'selected' : '' %>>Account</option>
          <option value="giftcard" <%= product?.category === 'giftcard' ? 'selected' : '' %>>Gift Card</option>
          <option value="other" <%= product?.category === 'other' ? 'selected' : '' %>>Other</option>
        </select>
      </div>
      <div class="form-group">
        <label>Badge (optional)</label>
        <select name="badge">
          <option value="" <%= !product?.badge ? 'selected' : '' %>>None</option>
          <option value="HOT" <%= product?.badge === 'HOT' ? 'selected' : '' %>>🔥 HOT</option>
          <option value="NEW" <%= product?.badge === 'NEW' ? 'selected' : '' %>>✨ NEW</option>
          <option value="SALE" <%= product?.badge === 'SALE' ? 'selected' : '' %>>💸 SALE</option>
        </select>
      </div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label>Stock *</label>
        <input type="number" name="stock" value="<%= product?.stock ?? 1 %>" min="0" required>
      </div>
      <% if (product) { %>
      <div class="form-group">
        <label>Visibility</label>
        <label class="toggle-label">
          <input type="checkbox" name="isActive" <%= product.isActive ? 'checked' : '' %>>
          <span>Active (visible in store)</span>
        </label>
      </div>
      <% } %>
    </div>

    <div class="form-group">
      <label>Product Image</label>
      <% if (product?.image && product.image !== '/images/default-game.png') { %>
        <div style="margin-bottom:8px"><img src="<%= product.image %>" style="height:80px;border-radius:8px;"></div>
      <% } %>
      <input type="file" name="image" accept="image/*">
      <small>Max 5MB. Leave blank to keep existing image.</small>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn-admin-primary">
        <%= product ? '💾 Save Changes' : '➕ Add Product' %>
      </button>
      <a href="/admin/products" class="btn-admin-outline">Cancel</a>
    </div>
  </form>
</div>

<%- include('partials/footer') %>
