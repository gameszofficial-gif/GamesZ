<%- include('partials/header', { title: 'Pay via UPI', user }) %>

<section class="upi-section">
  <div class="container">
    <div class="upi-wrapper">

      <!-- Left: Instructions + QR -->
      <div class="upi-left">
        <div class="upi-step-badge">Step 1 of 2 — Make Payment</div>
        <h1>Pay via UPI</h1>
        <p class="upi-sub">Use any UPI app to pay directly to our account</p>

        <div class="upi-apps-row">
          <span class="upi-app">GPay</span>
          <span class="upi-app">PhonePe</span>
          <span class="upi-app">Paytm</span>
          <span class="upi-app">BHIM</span>
        </div>

        <div class="upi-id-box">
          <div class="upi-id-label">UPI ID</div>
          <div class="upi-id-value" id="upiIdText"><%= upiId %></div>
          <button class="upi-copy-btn" onclick="copyUPI()">📋 Copy</button>
        </div>

        <div class="upi-name-row">
          <span>Pay to:</span> <strong><%= upiName %></strong>
        </div>

        <div class="upi-amount-box">
          <div class="upi-amount-label">Exact Amount to Pay</div>
          <div class="upi-amount">₹<%= order.amount %></div>
          <div class="upi-amount-note">Pay this exact amount. Different amounts cause delays.</div>
        </div>

        <!-- QR Code (generated from UPI deep link) -->
        <div class="upi-qr-block">
          <div class="upi-qr-label">Or scan QR code</div>
          <div class="qr-container">
            <canvas id="qrCanvas"></canvas>
          </div>
          <small style="color:var(--text-muted);font-size:12px">Scan with any UPI app camera</small>
        </div>

        <div class="upi-link-btn-wrap">
          <a class="upi-deeplink-btn" id="upiDeeplink" href="#">
            📱 Open in UPI App
          </a>
        </div>
      </div>

      <!-- Right: Upload Screenshot -->
      <div class="upi-right">
        <div class="upi-step-badge">Step 2 of 2 — Upload Proof</div>
        <h2>Upload Payment Screenshot</h2>
        <p class="upi-sub">After paying, take a screenshot and upload it below. We'll verify and deliver your product.</p>

        <form action="/orders/submit-proof/<%= order._id %>" method="POST" enctype="multipart/form-data" id="proofForm">

          <div class="form-group">
            <label>UPI Transaction ID / UTR Number <span style="color:var(--text-muted)">(optional but speeds up verification)</span></label>
            <input type="text" name="transactionId" placeholder="e.g. 4278364927364" class="upi-input">
          </div>

          <div class="form-group">
            <label>Payment Screenshot <span style="color:#ef4444">*</span></label>
            <div class="upload-zone" id="uploadZone">
              <input type="file" name="screenshot" id="screenshotInput" accept="image/*" required style="display:none">
              <div id="uploadPrompt">
                <div style="font-size:40px;margin-bottom:10px">📸</div>
                <div style="font-weight:700;color:var(--text)">Click to upload screenshot</div>
                <div style="font-size:13px;color:var(--text-muted);margin-top:6px">JPG, PNG or JPEG • Max 8MB</div>
              </div>
              <img id="previewImg" style="display:none;max-width:100%;max-height:220px;border-radius:8px;object-fit:contain;">
            </div>
          </div>

          <div class="upi-order-summary">
            <div class="summary-row"><span>Product</span><strong><%= order.productName %></strong></div>
            <div class="summary-row"><span>Order ID</span><strong style="font-size:12px;color:var(--text-muted)">#<%= order._id.toString().slice(-8).toUpperCase() %></strong></div>
            <div class="summary-row"><span>Amount</span><strong style="color:var(--accent)">₹<%= order.amount %></strong></div>
          </div>

          <button type="submit" class="btn-submit-proof" id="submitBtn">
            ✅ Submit Payment Proof
          </button>
          <p style="text-align:center;font-size:13px;color:var(--text-muted);margin-top:12px">
            We verify payments within a few minutes and will open your chat window.
          </p>
        </form>
      </div>

    </div>
  </div>
</section>

<!-- QR library -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<script>
  const upiId = '<%= upiId %>';
  const upiName = encodeURIComponent('<%= upiName %>');
  const amount = '<%= order.amount %>';
  const orderId = '<%= order._id %>';
  const note = encodeURIComponent('Gamesz Order #' + orderId.slice(-8).toUpperCase());

  // UPI deep link
  const upiLink = `upi://pay?pa=${upiId}&pn=${upiName}&am=${amount}&cu=INR&tn=${note}`;
  document.getElementById('upiDeeplink').href = upiLink;

  // QR Code
  new QRCode(document.getElementById('qrCanvas'), {
    text: upiLink,
    width: 200,
    height: 200,
    colorDark: '#e2e8f0',
    colorLight: '#0d1526',
    correctLevel: QRCode.CorrectLevel.M
  });

  // Copy UPI ID
  function copyUPI() {
    navigator.clipboard.writeText(upiId).then(() => {
      const btn = document.querySelector('.upi-copy-btn');
      btn.textContent = '✓ Copied!';
      setTimeout(() => btn.textContent = '📋 Copy', 2000);
    });
  }

  // File upload preview
  const uploadZone = document.getElementById('uploadZone');
  const fileInput = document.getElementById('screenshotInput');
  const previewImg = document.getElementById('previewImg');
  const uploadPrompt = document.getElementById('uploadPrompt');

  uploadZone.addEventListener('click', () => fileInput.click());
  uploadZone.addEventListener('dragover', e => { e.preventDefault(); uploadZone.classList.add('drag-over'); });
  uploadZone.addEventListener('dragleave', () => uploadZone.classList.remove('drag-over'));
  uploadZone.addEventListener('drop', e => {
    e.preventDefault();
    uploadZone.classList.remove('drag-over');
    const file = e.dataTransfer.files[0];
    if (file) showPreview(file);
    fileInput.files = e.dataTransfer.files;
  });
  fileInput.addEventListener('change', () => {
    if (fileInput.files[0]) showPreview(fileInput.files[0]);
  });

  function showPreview(file) {
    const reader = new FileReader();
    reader.onload = e => {
      previewImg.src = e.target.result;
      previewImg.style.display = 'block';
      uploadPrompt.style.display = 'none';
    };
    reader.readAsDataURL(file);
  }

  // Submit
  document.getElementById('proofForm').addEventListener('submit', () => {
    const btn = document.getElementById('submitBtn');
    btn.textContent = 'Uploading...';
    btn.disabled = true;
  });
</script>

<%- include('partials/footer') %>
