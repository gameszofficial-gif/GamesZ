<%- include('partials/header', { title: '2FA Setup' }) %>
<section class="auth-section">
  <div class="auth-card" style="max-width:480px">
    <div class="auth-logo"><span class="logo-g">G</span>AMESZ</div>
    <h2>🔐 Two-Factor Auth</h2>
    <p class="auth-sub">Secure your account with an authenticator app</p>
    <% if (typeof error !== 'undefined' && error) { %><div class="error-banner">⚠️ <%= error %></div><% } %>
    <% if (qrCode) { %>
    <div style="text-align:center;margin:20px 0">
      <img src="<%= qrCode %>" style="width:200px;height:200px;border-radius:8px;margin:0 auto">
      <p style="margin-top:12px;font-size:13px;color:var(--text-muted)">Scan with Google Authenticator or Authy</p>
      <div style="background:var(--bg-surface);border:1px solid var(--border);border-radius:8px;padding:12px;margin-top:12px;font-family:monospace;font-size:12px;color:var(--text-dim);word-break:break-all"><%= secret %></div>
    </div>
    <% } %>
    <form method="POST" action="/auth/2fa/verify" class="auth-form">
      <div class="form-group"><label>Enter 6-digit code from app</label><input type="text" name="token" placeholder="000000" maxlength="6" required autocomplete="one-time-code"></div>
      <button type="submit" class="btn-auth">✅ Verify & Enable 2FA</button>
    </form>
    <div class="auth-switch"><a href="/dashboard">← Back to Dashboard</a></div>
  </div>
</section>
<%- include('partials/footer') %>
